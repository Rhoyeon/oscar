# Oscar Harness Knowledge Base — SPARQL 예제 쿼리 10선
# Namespace: https://oscar.ai/harness/
# Graph TTL: _workspace/03_knowledge_graph.ttl
# 실행: rdflib / Apache Jena ARQ / GraphDB 등 표준 SPARQL 1.1 엔진 호환

PREFIX oscar:   <https://oscar.ai/harness/>
PREFIX inst:    <https://oscar.ai/harness/instance/>
PREFIX schema:  <https://schema.org/>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>


# Q1. 황민호(E001)가 created 한 모든 산출물(Harness 등) 조회
SELECT ?artifact ?label ?version WHERE {
  inst:Person/E001 oscar:created ?artifact .
  ?artifact rdfs:label ?label .
  OPTIONAL { ?artifact oscar:version ?version }
}


# Q2. revfactory/harness(E029)가 따르는 모든 디자인 원칙(DesignPrinciple)
SELECT ?principle ?principleLabel WHERE {
  inst:Harness/E029 oscar:follows ?principle .
  ?principle a oscar:DesignPrinciple ;
             rdfs:label ?principleLabel .
}


# Q3. revfactory/harness가 supportsPattern 으로 지원하는 아키텍처 패턴 목록
SELECT ?pattern ?patternLabel WHERE {
  inst:Harness/E029 oscar:supportsPattern ?pattern .
  ?pattern rdfs:label ?patternLabel .
} ORDER BY ?patternLabel


# Q4. BloomLabs Content Harness(E032)의 발행 매체(PublicationChannel) 전체
SELECT ?channel ?channelLabel WHERE {
  inst:Harness/E032 oscar:publishesTo ?channel .
  ?channel rdfs:label ?channelLabel .
}


# Q5. Claude Code Agent Teams(E021)를 활성화하는 환경 변수와 그 값,
#     해당 변수가 설정되는 ConfigurationFile 까지 한 번에 조회
SELECT ?env ?value ?configFile WHERE {
  inst:Technology/E021 oscar:activatedBy ?env .
  ?env oscar:envValue ?value ;
       oscar:configuredIn ?configFile .
}


# Q6. 엔지니어링 패러다임의 진화 체인 (evolvesInto)
SELECT ?from ?fromLabel ?to ?toLabel WHERE {
  ?from a oscar:EngineeringParadigm ;
        oscar:evolvesInto ?to ;
        rdfs:label ?fromLabel .
  ?to rdfs:label ?toLabel .
}


# Q7. revfactory/harness 의 6단계 워크플로우 단계 라벨 (순서 정렬)
SELECT ?step ?stepLabel WHERE {
  inst:Harness/E029 oscar:hasWorkflowStep ?step .
  ?step rdfs:label ?stepLabel .
  OPTIONAL { ?step oscar:stepOrder ?ord }
} ORDER BY ?ord ?stepLabel


# Q8. A/B 실험(E060)이 측정한 품질 지표와 before/after/improvement 값
SELECT ?metric ?metricLabel ?before ?after ?delta WHERE {
  inst:Experiment/E060 oscar:measures ?metric .
  ?metric rdfs:label ?metricLabel .
  OPTIONAL { ?metric oscar:beforeValue ?before }
  OPTIONAL { ?metric oscar:afterValue  ?after  }
  OPTIONAL { ?metric oscar:improvement ?delta  }
}


# Q9. 직무(Role)별 권장 아키텍처 패턴 매핑
SELECT ?roleLabel ?patternLabel WHERE {
  ?role a oscar:Role ;
        oscar:usesPattern ?pattern ;
        rdfs:label ?roleLabel .
  ?pattern rdfs:label ?patternLabel .
} ORDER BY ?roleLabel


# Q10. 가장 많이 연결된 허브 노드 Top 5 (out + in 차수 합)
SELECT ?node ?label (COUNT(?edge) AS ?degree) WHERE {
  ?node rdfs:label ?label .
  { ?node ?edge ?o . FILTER(STRSTARTS(STR(?edge), STR(oscar:))) }
  UNION
  { ?s ?edge ?node . FILTER(STRSTARTS(STR(?edge), STR(oscar:))) }
}
GROUP BY ?node ?label
ORDER BY DESC(?degree)
LIMIT 5
