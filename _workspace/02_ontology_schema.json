  "constraints": [
    {"id": "CN001", "type": "disjoint", "classes": ["C002", "C003"], "description": "Person과 Organization은 서로소."},
    {"id": "CN002", "type": "disjoint", "classes": ["C006", "C007", "C008"], "description": "TeamLead, Teammate, Subagent는 상호 배타적 AI 에이전트 유형."},
    {"id": "CN003", "type": "functional", "property": "P204", "description": "EnvironmentVariable는 정확히 하나의 ConfigurationFile에 설정된다."},
    {"id": "CN004", "type": "subPropertyOf", "property": "P006", "parent": "P005", "description": "authored는 created의 하위 속성."},
    {"id": "CN005", "type": "inverseOf", "property": "P004", "inverse": "hasPart", "description": "partOf의 역속성은 hasPart."},
    {"id": "CN006", "type": "transitive", "property": "P401", "description": "subClassOf는 추이적 속성."},
    {"id": "CN007", "type": "domainRule", "rule": "C402 인스턴스는 반드시 하나의 C401에 속해야 함 (P301의 역참조 필수)."},
    {"id": "CN008", "type": "rangeRule", "property": "P514", "rule": "year는 1900~2100 범위의 gYear."}
