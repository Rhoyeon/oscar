@prefix harness: <https://oscar.ai/harness/> .
@prefix oscar: <https://oscar.ai/harness/instance/> .
@prefix ocls: <https://oscar.ai/harness/class/> .
@prefix oprop: <https://oscar.ai/harness/property/> .
@prefix schema: <https://schema.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ---- Class hierarchy (subset) ----
ocls:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf ocls:Agent ;
    owl:equivalentClass schema:Person ;
    rdfs:comment "개인 인물." .

ocls:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:subClassOf ocls:Agent ;
    owl:equivalentClass schema:Organization ;
    rdfs:comment "조직 또는 기업." .

ocls:Team a owl:Class ;
    rdfs:label "Team" ;
    rdfs:subClassOf ocls:Organization ;
    owl:equivalentClass schema:Organization ;
    rdfs:comment "조직 내부의 팀/부서." .

ocls:AIAgent a owl:Class ;
    rdfs:label "AIAgent" ;
    rdfs:subClassOf ocls:Agent ;
    rdfs:comment "AI 기반 자율 에이전트 (.claude/agents/에 정의되는 페르소나 포함)." .

ocls:TeamLead a owl:Class ;
    rdfs:label "TeamLead" ;
    rdfs:subClassOf ocls:AIAgent ;
    rdfs:comment "Agent Teams의 메인 세션, 작업 할당과 결과 종합 담당." .

ocls:Teammate a owl:Class ;
    rdfs:label "Teammate" ;
    rdfs:subClassOf ocls:AIAgent ;
    rdfs:comment "독립 컨텍스트 윈도우를 갖는 Claude Code 인스턴스." .

ocls:Subagent a owl:Class ;
    rdfs:label "Subagent" ;
    rdfs:subClassOf ocls:AIAgent ;
    rdfs:comment "메인 에이전트에게만 통신하는 서브 에이전트." .

ocls:Concept a owl:Class ;
    rdfs:label "Concept" ;
    owl:equivalentClass schema:DefinedTerm ;
    rdfs:comment "추상 개념, 철학, 방법론, 원칙 등 하네스 도메인 지식의 단위." .

ocls:EngineeringParadigm a owl:Class ;
    rdfs:label "EngineeringParadigm" ;
    rdfs:subClassOf ocls:Concept ;
    rdfs:comment "AI 엔지니어링 패러다임 (프롬프트/컨텍스트/하네스 엔지니어링)." .

ocls:DesignPrinciple a owl:Class ;
    rdfs:label "DesignPrinciple" ;
    rdfs:subClassOf ocls:Concept ;
    rdfs:comment "하네스 설계 철학/원칙 (Progressive Disclosure, Why-First, 경계 검증 등)." .

ocls:Strategy a owl:Class ;
    rdfs:label "Strategy" ;
    rdfs:subClassOf ocls:Concept ;
    rdfs:comment "조직/제품 전략 (예: AI Native 전략)." .

ocls:Mechanism a owl:Class ;
    rdfs:label "Mechanism" ;
    rdfs:subClassOf ocls:Concept ;
    rdfs:comment "기술 메커니즘 (컴팩션, 이벤트 소싱, 스냅샷 압축 등)." .

ocls:Role a owl:Class ;
    rdfs:label "Role" ;
    rdfs:subClassOf ocls:Concept ;
    owl:equivalentClass schema:Role ;
    rdfs:comment "전문가 직무/역할 (개발자, PM, QA 등)." .

ocls:License a owl:Class ;
    rdfs:label "License" ;
    rdfs:subClassOf ocls:Concept ;
    owl:equivalentClass schema:CreativeWork ;
    rdfs:comment "오픈소스 라이선스." .

ocls:ArchitecturePattern a owl:Class ;
    rdfs:label "ArchitecturePattern" ;
    rdfs:comment "에이전트 오케스트레이션 아키텍처 패턴 (Pipeline, Fan-out/Fan-in 등)." .

ocls:Harness a owl:Class ;
    rdfs:label "Harness" ;
    rdfs:subClassOf ocls:Artifact ;
    owl:equivalentClass schema:SoftwareApplication ;
    rdfs:comment "AI 에이전트 행동을 구조화하는 사전 설정 체계 (제품 단위)." .

ocls:Technology a owl:Class ;
    rdfs:label "Technology" ;
    rdfs:subClassOf ocls:Artifact ;
    owl:equivalentClass schema:SoftwareApplication ;
    rdfs:comment "하네스가 동작하는 기반 기술/플랫폼." .

ocls:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:subClassOf ocls:Artifact ;
    rdfs:comment ".claude/skills/에 정의되는 재사용 가능한 절차적 지식." .

ocls:MetaSkill a owl:Class ;
    rdfs:label "MetaSkill" ;
    rdfs:subClassOf ocls:Skill ;
    rdfs:comment "스킬을 만드는 스킬." .

ocls:ConfigurationFile a owl:Class ;
    rdfs:label "ConfigurationFile" ;
    rdfs:subClassOf ocls:Artifact ;
    rdfs:comment "하네스/플랫폼 설정 파일 (예: settings.json)." .

ocls:EnvironmentVariable a owl:Class ;
    rdfs:label "EnvironmentVariable" ;
    rdfs:subClassOf ocls:Artifact ;
    rdfs:comment "런타임 환경 변수." .

ocls:PublicationChannel a owl:Class ;
    rdfs:label "PublicationChannel" ;
    rdfs:subClassOf ocls:Artifact ;
    owl:equivalentClass schema:WebSite ;
    rdfs:comment "콘텐츠 발행 매체 (Confluence, Wiki 등)." .

ocls:CommunicationChannel a owl:Class ;
    rdfs:label "CommunicationChannel" ;
    rdfs:subClassOf ocls:Artifact ;
    rdfs:comment "에이전트 간 협업/통신 메커니즘 (Shared Task List, Mailbox)." .

ocls:Workflow a owl:Class ;
    rdfs:label "Workflow" ;
    rdfs:subClassOf ocls:Process ;
    rdfs:comment "다단계 절차 (예: 6단계 하네스 구축 워크플로우, 7 State 워크플로우)." .

ocls:WorkflowStep a owl:Class ;
    rdfs:label "WorkflowStep" ;
    rdfs:subClassOf ocls:Process ;
    rdfs:comment "워크플로우 내 개별 단계." .

ocls:Experiment a owl:Class ;
    rdfs:label "Experiment" ;
    rdfs:subClassOf ocls:Process ;
    owl:equivalentClass schema:Observation ;
    rdfs:comment "검증 실험 (예: A/B 실험)." .

ocls:EvaluationSystem a owl:Class ;
    rdfs:label "EvaluationSystem" ;
    rdfs:subClassOf ocls:Metric ;
    rdfs:comment "다축 평가 체계 (5축 100점, 디자인 3축 100점 등)." .

ocls:QualityMetric a owl:Class ;
    rdfs:label "QualityMetric" ;
    rdfs:subClassOf ocls:Metric ;
    owl:equivalentClass schema:PropertyValue ;
    rdfs:comment "품질 점수, 승률, 출력 분산 같은 단일 지표." .

# ---- Object/Data Properties ----
oprop:worksFor a owl:ObjectProperty ;
    rdfs:label "worksFor" ;
    rdfs:domain ocls:Person ;
    rdfs:range ocls:Organization ;
    owl:equivalentProperty schema:worksFor ;
    rdfs:comment "Mapped from predicate worksFor" .

oprop:leads a owl:ObjectProperty ;
    rdfs:label "leads" ;
    rdfs:domain ocls:Person ;
    rdfs:range ocls:Organization ;
    rdfs:comment "Mapped from predicate leads" .

oprop:partOf a owl:ObjectProperty ;
    rdfs:label "partOf" ;
    rdfs:domain ocls:Organization ;
    rdfs:range ocls:Organization ;
    owl:equivalentProperty schema:parentOrganization ;
    rdfs:comment "Mapped from predicate partOf" .

oprop:created a owl:ObjectProperty ;
    rdfs:label "created" ;
    rdfs:domain ocls:Agent ;
    rdfs:range ocls:Artifact ;
    owl:equivalentProperty schema:creator ;
    rdfs:comment "Mapped from predicate created" .

oprop:authored a owl:ObjectProperty ;
    rdfs:label "authored" ;
    rdfs:domain ocls:Person ;
    rdfs:range ocls:Artifact ;
    owl:equivalentProperty schema:author ;
    rdfs:comment "Mapped from predicate authored" .

oprop:operates a owl:ObjectProperty ;
    rdfs:label "operates" ;
    rdfs:domain ocls:Organization ;
    rdfs:range ocls:Harness ;
    rdfs:comment "Mapped from predicate operates" .

oprop:drives a owl:ObjectProperty ;
    rdfs:label "drives" ;
    rdfs:domain ocls:Organization ;
    rdfs:range ocls:Strategy ;
    rdfs:comment "Mapped from predicate drives" .

oprop:quotedAbout a owl:ObjectProperty ;
    rdfs:label "quotedAbout" ;
    rdfs:domain ocls:Person ;
    rdfs:range ocls:Artifact ;
    rdfs:comment "Mapped from predicate quotedAbout" .

oprop:follows a owl:ObjectProperty ;
    rdfs:label "follows" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:DesignPrinciple ;
    rdfs:comment "Mapped from predicate follows" .

oprop:supportsPattern a owl:ObjectProperty ;
    rdfs:label "supportsPattern" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:ArchitecturePattern ;
    rdfs:comment "Mapped from predicate supportsPattern" .

oprop:usesPattern a owl:ObjectProperty ;
    rdfs:label "usesPattern" ;
    rdfs:domain ocls:Artifact ;
    rdfs:range ocls:ArchitecturePattern ;
    rdfs:comment "Mapped from predicate usesPattern" .

oprop:implements a owl:ObjectProperty ;
    rdfs:label "implements" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:Skill ;
    rdfs:comment "Mapped from predicate implements" .

oprop:definesAgent a owl:ObjectProperty ;
    rdfs:label "definesAgent" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:AIAgent ;
    rdfs:comment "Mapped from predicate definesAgent" .

oprop:appliedTo a owl:ObjectProperty ;
    rdfs:label "appliedTo" ;
    rdfs:domain ocls:EngineeringParadigm ;
    rdfs:range ocls:Technology ;
    rdfs:comment "Mapped from predicate appliedTo" .

oprop:evolvesInto a owl:ObjectProperty ;
    rdfs:label "evolvesInto" ;
    rdfs:domain ocls:EngineeringParadigm ;
    rdfs:range ocls:EngineeringParadigm ;
    rdfs:comment "Mapped from predicate evolvesInto" .

oprop:hasMechanism a owl:ObjectProperty ;
    rdfs:label "hasMechanism" ;
    rdfs:domain ocls:Technology ;
    rdfs:range ocls:Mechanism ;
    rdfs:comment "Mapped from predicate hasMechanism" .

oprop:logsVia a owl:ObjectProperty ;
    rdfs:label "logsVia" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:Mechanism ;
    rdfs:comment "Mapped from predicate logsVia" .

oprop:featureOf a owl:ObjectProperty ;
    rdfs:label "featureOf" ;
    rdfs:domain ocls:Technology ;
    rdfs:range ocls:Technology ;
    rdfs:comment "Mapped from predicate featureOf" .

oprop:includes a owl:ObjectProperty ;
    rdfs:label "includes" ;
    rdfs:domain ocls:Technology ;
    rdfs:range ocls:Agent ;
    rdfs:comment "Mapped from predicate includes" .

oprop:uses a owl:ObjectProperty ;
    rdfs:label "uses" ;
    rdfs:domain ocls:Technology ;
    rdfs:range ocls:Artifact ;
    rdfs:comment "Mapped from predicate uses" .

oprop:activatedBy a owl:ObjectProperty ;
    rdfs:label "activatedBy" ;
    rdfs:domain ocls:Technology ;
    rdfs:range ocls:EnvironmentVariable ;
    rdfs:comment "Mapped from predicate activatedBy" .

oprop:configuredIn a owl:ObjectProperty ;
    rdfs:label "configuredIn" ;
    rdfs:domain ocls:EnvironmentVariable ;
    rdfs:range ocls:ConfigurationFile ;
    rdfs:comment "Mapped from predicate configuredIn" .

oprop:differsFrom a owl:ObjectProperty ;
    rdfs:label "differsFrom" ;
    rdfs:domain ocls:AIAgent ;
    rdfs:range ocls:AIAgent ;
    rdfs:comment "Mapped from predicate differsFrom" .

oprop:publishesTo a owl:ObjectProperty ;
    rdfs:label "publishesTo" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:PublicationChannel ;
    rdfs:comment "Mapped from predicate publishesTo" .

oprop:licensedUnder a owl:ObjectProperty ;
    rdfs:label "licensedUnder" ;
    rdfs:domain ocls:Artifact ;
    rdfs:range ocls:License ;
    owl:equivalentProperty schema:license ;
    rdfs:comment "Mapped from predicate licensedUnder" .

oprop:hasWorkflow a owl:ObjectProperty ;
    rdfs:label "hasWorkflow" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:Workflow ;
    rdfs:comment "Mapped from predicate hasWorkflow" .

oprop:hasWorkflowStep a owl:ObjectProperty ;
    rdfs:label "hasWorkflowStep" ;
    rdfs:domain ocls:Workflow ;
    rdfs:range ocls:WorkflowStep ;
    owl:equivalentProperty schema:step ;
    rdfs:comment "Mapped from predicate hasWorkflowStep" .

oprop:validatedBy a owl:ObjectProperty ;
    rdfs:label "validatedBy" ;
    rdfs:domain ocls:Harness ;
    rdfs:range ocls:Experiment ;
    rdfs:comment "Mapped from predicate validatedBy" .

oprop:measures a owl:ObjectProperty ;
    rdfs:label "measures" ;
    rdfs:domain ocls:Experiment ;
    rdfs:range ocls:Metric ;
    rdfs:comment "Mapped from predicate measures" .

