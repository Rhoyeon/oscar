{
  "version": "1.0.0",
  "created_at": "2026-05-03",
  "source_url": "https://wiki.webnori.com/pages/viewpage.action?pageId=125731373",
  "namespace": "https://oscar.ai/harness/",
  "ontology_classes": 33,
  "ontology_properties": 51,
  "ontology_constraints": 8,
  "graph_nodes": 70,
  "graph_edges": 68,
  "graph_isolated_nodes": 5,
  "rag_embeddings": 208,
  "rag_collections": ["nodes", "edges", "subgraphs"],
  "embedding_backend_default": "sentence-transformers",
  "vector_backend_default": "chroma",
  "interfaces": ["skill", "python_api", "sparql", "natural_language"],
  "output_files": [
    {
      "path": "output/oscar_interface.md",
      "type": "skill",
      "name": "oscar-harness-kb",
      "description": "Claude Code 스킬 정의 (YAML frontmatter + 사용 가이드)"
    },
    {
      "path": "output/oscar_api.py",
      "type": "python_api",
      "exports": ["query", "get_node", "get_neighbors", "get_subgraph"],
      "description": "지식그래프 조회용 Python 래퍼 (setup_rag.py 위임)"
    },
    {
      "path": "output/oscar.py",
      "type": "python_api_shim",
      "description": "from oscar import ... 형태를 위한 재수출 모듈"
    },
    {
      "path": "output/oscar_queries.sparql",
      "type": "sparql",
      "query_count": 10,
      "description": "온톨로지 클래스/속성을 활용하는 예제 SPARQL 쿼리 10선"
    },
    {
      "path": "output/oscar_summary.md",
      "type": "report",
      "description": "파이프라인 결과 요약, 허브 Top5, 예시 쿼리, 활용 가이드"
    }
  ],
  "input_files": [
    "_workspace/02_ontology_schema.json",
    "_workspace/03_knowledge_graph.json",
    "_workspace/03_knowledge_graph.ttl",
    "_workspace/04_rag_config.json",
    "_workspace/scripts/setup_rag.py"
  ],
  "hub_nodes_top5": [
    {"entity_id": "E029", "label": "revfactory/harness", "class": "Harness", "degree": 23},
    {"entity_id": "E032", "label": "BloomLabs Content Harness", "class": "Harness", "degree": 15},
    {"entity_id": "E021", "label": "Claude Code Agent Teams", "class": "Technology", "degree": 8},
    {"entity_id": "E001", "label": "황민호", "class": "Person", "degree": 5},
    {"entity_id": "E060", "label": "A/B 실험", "class": "Experiment", "degree": 4}
  ]
}
